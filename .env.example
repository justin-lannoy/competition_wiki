ANTHROPIC_API_KEY=sk-ant-...

# GitHub PAT for unattended pushes (used by scripts/refresh_and_push.sh).
# Classic (`ghp_*`) or fine-grained PAT — needs Contents: Read & write on this
# repo and SSO authorization for the SnapFinance org. The wrapper exposes it
# via an inline `git -c credential.helper=…` that prints
# `username=x-access-token` + `password=$GITHUB_TOKEN`, so the token never
# lands in `.git/config`, remote URLs, or any persisted credential store.
# If unset, the wrapper falls back to the macOS keychain helper.
GITHUB_TOKEN=ghp_...

# Optional: Slack incoming-webhook URL for failure alerts. When set,
# scripts/refresh_and_push.sh POSTs here on any non-zero exit (git/auth/
# pipeline/build failure) with the tail of the run log, so a dead weekly run
# is visible instead of silent. Create one at api.slack.com → Incoming Webhooks.
# Leave unset to disable alerting. (Catches in-run failures only — not the case
# where launchd never fires because the Mac was off; see AGENT_RUNBOOK.md.)
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/...
